# Optional overrides for ps5-ffpfsc-tools.
# Source this before running commands, or pass values inline.

export PS5_ROOT="$HOME/ps5"
export PS5_OUT="$HOME/Downloads/ps5/out"
export PS5_SCRATCH="$PS5_ROOT/scratch"
export PS5_LOGS="$PS5_ROOT/logs"
export PS5_HISTORY="$PS5_ROOT/history.jsonl"

# Optional: force pack worker count instead of auto using total CPUs minus two.
# export PS5_CPU_COUNT=14

# Space-separated roots scanned by `ps5-ffpfsc scan`.
export PS5_SCAN_ROOTS="$HOME/Downloads /mnt/mac/Downloads"

# USB/SMB mount used by `copy`, `ssd`, `ssd-rm`, and `clean-ssd`.
export PS5_SSD="/mnt/drive"
export PS5_SSD_HOME="$PS5_SSD/homebrew"
